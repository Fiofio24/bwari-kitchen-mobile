{
  "expo": {
    "name": "Bwari Kitchen",
    "slug": "bwari-kitchen",
    "version": "2.4.0",
    "orientation": "portrait",
    "icon": "./assets/BK_logo12-r.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#d30000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fiotecz.bwarikitchen"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/BK_logo1-w.png",
        "backgroundColor": "#d30000"
      },
      "package": "com.fiotecz.bwarikitchen"
    },
    "web": {
      "favicon": "./assets/BK_logo12-r.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "bwarikitchen",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b43549ec-ac0e-47ad-b457-19de98b6237f"
      }
    }
  }
}
